# ===================== VibeGuard secure env template =====================
# Copy to .env.local. NEVER commit real secrets — .env* is gitignored. (VG-007, VG-008)
# Generate high-entropy secrets, e.g.:  openssl rand -base64 48

# --- PUBLIC: safe to expose to the browser (anon/publishable only) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# --- SERVER-ONLY: NEVER prefix with NEXT_PUBLIC_, never send to the client ---
SUPABASE_SERVICE_ROLE_KEY=server-side-only        # bypasses RLS — never expose (VG-008)
STRIPE_SECRET_KEY=sk_live_xxx                      # server-only (VG-008)
SESSION_SECRET=generate-with-csprng-32-bytes-min   # never reuse a default (VG-007)
